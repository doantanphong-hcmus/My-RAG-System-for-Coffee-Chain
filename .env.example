# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL / Supabase Database URL
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
# Example from Supabase: postgresql://postgres.xxxxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=your_supabase_postgresql_url_here
